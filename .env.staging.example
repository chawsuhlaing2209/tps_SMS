# Staging environment template
# Copy to `.env.staging` locally or inject via your hosting provider's secret manager.

NODE_ENV=production

WEB_APP_URL=https://staging.your-school-saas.example
API_PORT=4000
API_ALLOWED_ORIGINS=https://staging.your-school-saas.example

NEXT_PUBLIC_API_BASE_URL=https://api-staging.your-school-saas.example

# Managed PostgreSQL (enable SSL in production)
DATABASE_URL=postgres://sms_staging:REPLACE_ME@staging-db.example.com:5432/sms_staging?sslmode=require
# REQUIRED off-laptop: least-privilege RLS role for the running API.
# After migrating, set its password: ALTER ROLE sms_app WITH PASSWORD '...';
APP_DATABASE_URL=postgres://sms_app:REPLACE_ME@staging-db.example.com:5432/sms_staging?sslmode=require

# Managed Redis
REDIS_URL=rediss://:REPLACE_ME@staging-redis.example.com:6379

# Generate with: openssl rand -base64 48
SESSION_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET

# Object storage (S3-compatible)
S3_ENDPOINT=https://s3.ap-southeast-1.amazonaws.com
S3_REGION=ap-southeast-1
S3_BUCKET=sms-staging-files
S3_ACCESS_KEY_ID=REPLACE_ME
S3_SECRET_ACCESS_KEY=REPLACE_ME

# Email — use a real provider in staging
EMAIL_PROVIDER=resend
EMAIL_FROM=no-reply@staging.your-school-saas.example
RESEND_API_KEY=REPLACE_ME

# Optional: backup destination for scripts/db-backup.sh
BACKUP_DIR=/var/backups/sms-staging
