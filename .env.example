NODE_ENV=development

WEB_APP_URL=http://localhost:3000
API_PORT=4000
API_ALLOWED_ORIGINS=http://localhost:3000

# Base URL the web app uses to call the API. Defaults to http://localhost:4000.
# For the Next.js web app, set this in apps/web/.env.local to override.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

DATABASE_URL=postgres://sms:sms@localhost:5432/sms
# Least-privilege role the API/worker connect as (subject to RLS). Falls back
# to DATABASE_URL when unset. Role is created by migration 0037.
APP_DATABASE_URL=postgres://sms_app:sms_app@localhost:5432/sms
REDIS_URL=redis://localhost:6379

SESSION_SECRET=replace-with-a-long-random-secret

S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=sms-local
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio-password

EMAIL_PROVIDER=console
EMAIL_FROM=no-reply@example.edu.mm
